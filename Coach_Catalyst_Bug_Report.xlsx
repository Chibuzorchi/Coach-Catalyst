# Add data to worksheet
for row, data in enumerate(bug_data, 2):
    for col, value in enumerate(data, 1):
        ws.cell(row=row, column=col, value=value)

# Apply formatting
thin_border = Border(
    left=Side(style='thin'),
    right=Side(style='thin'),
    top=Side(style='thin'),
    bottom=Side(style='thin')
)

# Apply borders and alignment to all cells
for row in ws.iter_rows():
    for cell in row:
        cell.border = thin_border
        cell.alignment = Alignment(vertical="top", wrap_text=True)

# Set column widths
column_widths = [10, 40, 15, 50, 40, 40, 25, 10, 10, 12, 15, 15, 15, 12, 15, 15, 20, 30, 20]
for i, width in enumerate(column_widths, 1):
    ws.column_dimensions[ws.cell(row=1, column=i).column_letter].width = width

# Freeze the header row
ws.freeze_panes = "A2"

# Add filters
ws.auto_filter.ref = f"A1:{ws.cell(row=1, column=len(headers)).column_letter}1"

# Add conditional formatting for severity
from openpyxl.formatting.rule import ColorScaleRule

# Color code severity levels
critical_fill = PatternFill(start_color="FF0000", end_color="FF0000", fill_type="solid")
high_fill = PatternFill(start_color="FFA500", end_color="FFA500", fill_type="solid")
medium_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
low_fill = PatternFill(start_color="90EE90", end_color="90EE90", fill_type="solid")

# Apply severity coloring
for row in range(2, len(bug_data) + 2):
    severity_cell = ws.cell(row=row, column=8)  # Severity column
    if severity_cell.value == "Critical":
        severity_cell.fill = critical_fill
    elif severity_cell.value == "High":
        severity_cell.fill = high_fill
    elif severity_cell.value == "Medium":
        severity_cell.fill = medium_fill
    elif severity_cell.value == "Low":
        severity_cell.fill = low_fill

# Save the workbook
wb.save("/workspace/Coach_Catalyst_Bug_Report.xlsx")