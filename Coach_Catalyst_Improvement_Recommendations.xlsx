# Add data to worksheet
for row, data in enumerate(recommendations_data, 2):
    for col, value in enumerate(data, 1):
        ws.cell(row=row, column=col, value=value)

# Apply formatting
thin_border = Border(
    left=Side(style='thin'),
    right=Side(style='thin'),
    top=Side(style='thin'),
    bottom=Side(style='thin')
)

# Apply borders and alignment to all cells
for row in ws.iter_rows():
    for cell in row:
        cell.border = thin_border
        cell.alignment = Alignment(vertical="top", wrap_text=True)

# Set column widths
column_widths = [8, 15, 25, 30, 30, 40, 30, 10, 12, 12, 15, 12, 15, 30]
for i, width in enumerate(column_widths, 1):
    ws.column_dimensions[ws.cell(row=1, column=i).column_letter].width = width

# Freeze the header row
ws.freeze_panes = "A2"

# Add filters
ws.auto_filter.ref = f"A1:{ws.cell(row=1, column=len(headers)).column_letter}1"

# Save the workbook
wb.save("/workspace/Coach_Catalyst_Improvement_Recommendations.xlsx")